<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:NAPLPSApp.ViewModels"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:views="clr-namespace:NAPLPSApp.Views"
		xmlns:i="https://github.com/projektanker/icons.avalonia"
		xmlns:converters="clr-namespace:NAPLPSApp.Converters"
		xmlns:Media="using:Avalonia.Media"
		mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
		x:Class="NAPLPSApp.Views.MainWindow"
		x:DataType="vm:MainWindowViewModel"
		Icon="/Assets/naplps.ico"
		Title="{Binding TitleBarDisplay}">
	<Window.KeyBindings>
		<KeyBinding Command="{Binding PreviousFrameCommand}" Gesture="Left"/>
		<KeyBinding Command="{Binding NextFrameCommand}" Gesture="Right"/>
		<KeyBinding Command="{Binding FirstFrameCommand}" Gesture="Home"/>
		<KeyBinding Command="{Binding LastFrameCommand}" Gesture="End"/>
		<KeyBinding Command="{Binding UndoCommand}" Gesture="Ctrl+Z"/>
		<KeyBinding Command="{Binding RedoCommand}" Gesture="Ctrl+Y"/>
		<KeyBinding Command="{Binding SaveCommand}" Gesture="Ctrl+S"/>
		<KeyBinding Command="{Binding SaveAsCommand}" Gesture="Ctrl+Shift+S"/>
		<KeyBinding Command="{Binding DeleteSelectedCommand}" Gesture="Delete"/>
	</Window.KeyBindings>

	<Window.Resources>
		<converters:EqualityConverter x:Key="EqualityConverter" />
		<converters:InequalityConverter x:Key="InequalityConverter" />
	</Window.Resources>

	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>

	<DockPanel>
		<Menu DockPanel.Dock="Top">
			<MenuItem Header="_File">
				<MenuItem Header="_New" Command="{Binding NewCommand}" i:MenuItem.Icon="fa-solid fa-file"/>
				<Separator/>
				<MenuItem Header="_Open" Command="{Binding OpenCommand}"  i:MenuItem.Icon="fa-solid fa-folder-open"/>
				<MenuItem Header="_Save" Command="{Binding SaveCommand}" IsEnabled="{Binding IsFileLoaded}" i:MenuItem.Icon="fa-solid fa-floppy-disk" InputGesture="Ctrl+S"/>
				<MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}" IsEnabled="{Binding IsFileLoaded}" i:MenuItem.Icon="fa-solid fa-floppy-disk" InputGesture="Ctrl+Shift+S"/>
				<MenuItem Header="_Close" Command="{Binding CloseCommand}" IsEnabled="{Binding IsFileLoaded}" i:MenuItem.Icon="fa-solid fa-circle-xmark"/>
				<Separator/>
				<MenuItem Header="_Export PNG" Command="{Binding ExportCommand}" IsEnabled="{Binding IsFileLoaded}" i:MenuItem.Icon="fa-solid fa-file-export"/>
				<Separator/>
				<MenuItem Header="_Properties" Command="{Binding PropertiesCommand}" IsEnabled="{Binding IsFileLoaded}" i:MenuItem.Icon="fa-solid fa-circle-info"/>
				<Separator/>
				<MenuItem Header="_Quit" Command="{Binding QuitCommand}" i:MenuItem.Icon="fa-solid fa-door-open"/>
			</MenuItem>
			<MenuItem Header="_Edit">
				<MenuItem Header="_Undo" Command="{Binding UndoCommand}" i:MenuItem.Icon="fa-solid fa-rotate-left" InputGesture="Ctrl+Z"/>
				<MenuItem Header="_Redo" Command="{Binding RedoCommand}" i:MenuItem.Icon="fa-solid fa-rotate-right" InputGesture="Ctrl+Y"/>
				<Separator/>
				<MenuItem Header="_Toolbox" Command="{Binding ToggleToolboxCommand}" IsEnabled="{Binding IsFileLoaded}" i:MenuItem.Icon="fa-solid fa-pen-ruler"></MenuItem>
				<Separator/>
				<MenuItem Header="_Group Layers" IsEnabled="false"></MenuItem>
				<MenuItem Header="_Ungroup Layers" IsEnabled="false"></MenuItem>
				<Separator/>
				<MenuItem Header="_Layers" Command="{Binding ToggleLayersCommand}" IsEnabled="{Binding IsFileLoaded}" i:MenuItem.Icon="fa-solid fa-layer-group"/>
			</MenuItem>
			<MenuItem Header="_Render">
				<MenuItem Header="_Re-render" Command="{Binding RerenderCommand}" IsEnabled="{Binding IsFileLoaded}" i:MenuItem.Icon="fa-solid fa-recycle"/>
				<Separator/>
				<MenuItem Header="_Animate" Command="{Binding ToggleAnimateCommand}" IsVisible="{Binding IsAnimated}" i:MenuItem.Icon="fa-solid fa-check"/>
				<MenuItem Header="_Animate" Command="{Binding ToggleAnimateCommand}" IsVisible="{Binding !IsAnimated}"/>
				<MenuItem Header="_Loop" Command="{Binding ToggleLoopCommand}" ToggleType="CheckBox" IsChecked="{Binding IsLooping}" i:MenuItem.Icon="fa-solid fa-repeat"/>
				<MenuItem Header="_Palette Animation" Command="{Binding TogglePaletteAnimationCommand}" ToggleType="CheckBox" IsChecked="{Binding IsPaletteAnimationMode}" i:MenuItem.Icon="fa-solid fa-palette"/>
				<Separator/>
				<MenuItem Header="_Speed" i:MenuItem.Icon="fa-solid fa-gauge">
					<MenuItem Header="Fastest" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="0" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=0}" />
					<MenuItem Header="460Kbps" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="460800" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=460800}" />
					<MenuItem Header="230Kbps" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="230400" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=230400}" />
					<MenuItem Header="115Kbps" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="115200" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=115200}" />
					<MenuItem Header="56Kbps" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="57600" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=57600}" />
					<MenuItem Header="38.4Kbps" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="38400" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=38400}" />
					<MenuItem Header="33.6Kbps" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="33600" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=33600}" />
					<MenuItem Header="28.8Kbps" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="28800" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=28800}" />
					<MenuItem Header="19.2Kbps" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="19200" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=19200}" />
					<MenuItem Header="14.4Kbps" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="14400" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=14400}" />
					<MenuItem Header="9.6Kbps" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="9600" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=9600}" />
					<MenuItem Header="2.4Kbps" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="2400" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=2400}" />
					<MenuItem Header="1.2Kbps" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="1200" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=1200}" />
					<MenuItem Header="300bps" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="300" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=300}" />
					<MenuItem Header="110bps" Command="{Binding SetBaudRateCommand}" ToggleType="CheckBox" CommandParameter="110" IsChecked="{Binding BaudRate, Converter={StaticResource EqualityConverter}, ConverterParameter=110}" />
				</MenuItem>
			</MenuItem>
			<MenuItem Header="_View">
				<MenuItem Header="_Sequence" Command="{Binding ToggleSequenceCommand}" IsEnabled="{Binding IsFileLoaded}" i:MenuItem.Icon="fa-solid fa-shoe-prints"/>
				<Separator/>
				<MenuItem Header="_Canvas Size" i:MenuItem.Icon="fa-solid fa-display">
					<MenuItem Header="160x120" Command="{Binding SetCanvasSizeCommand}" ToggleType="CheckBox" CommandParameter="160x120" IsChecked="{Binding CanvasSize, Converter={StaticResource EqualityConverter}, ConverterParameter='160x120'}" />
					<MenuItem Header="320x200" Command="{Binding SetCanvasSizeCommand}" ToggleType="CheckBox" CommandParameter="320x200" IsChecked="{Binding CanvasSize, Converter={StaticResource EqualityConverter}, ConverterParameter='320x200'}" />
					<MenuItem Header="320x240" Command="{Binding SetCanvasSizeCommand}" ToggleType="CheckBox" CommandParameter="320x240" IsChecked="{Binding CanvasSize, Converter={StaticResource EqualityConverter}, ConverterParameter='320x240'}" />
					<MenuItem Header="640x480" Command="{Binding SetCanvasSizeCommand}" ToggleType="CheckBox" CommandParameter="640x480" IsChecked="{Binding CanvasSize, Converter={StaticResource EqualityConverter}, ConverterParameter='640x480'}" />
					<MenuItem Header="800x600" Command="{Binding SetCanvasSizeCommand}" ToggleType="CheckBox" CommandParameter="800x600" IsChecked="{Binding CanvasSize, Converter={StaticResource EqualityConverter}, ConverterParameter='800x600'}" />
					<MenuItem Header="1024x768" Command="{Binding SetCanvasSizeCommand}" ToggleType="CheckBox" CommandParameter="1024x768" IsChecked="{Binding CanvasSize, Converter={StaticResource EqualityConverter}, ConverterParameter='1024x768'}" />
					<MenuItem Header="1280x960" Command="{Binding SetCanvasSizeCommand}" ToggleType="CheckBox" CommandParameter="1280x960" IsChecked="{Binding CanvasSize, Converter={StaticResource EqualityConverter}, ConverterParameter='1280x960'}" />
					<MenuItem Header="1600x1200" Command="{Binding SetCanvasSizeCommand}" ToggleType="CheckBox" CommandParameter="1600x1200" IsChecked="{Binding CanvasSize, Converter={StaticResource EqualityConverter}, ConverterParameter='1600x1200'}" />
					<MenuItem Header="2048x1536" Command="{Binding SetCanvasSizeCommand}" ToggleType="CheckBox" CommandParameter="2048x1536" IsChecked="{Binding CanvasSize, Converter={StaticResource EqualityConverter}, ConverterParameter='2048x1536'}" />
					<MenuItem Header="4096x3072" Command="{Binding SetCanvasSizeCommand}" ToggleType="CheckBox" CommandParameter="4096x3072" IsChecked="{Binding CanvasSize, Converter={StaticResource EqualityConverter}, ConverterParameter='4096x3072'}" />
				</MenuItem>
				<MenuItem Header="_Display Ratio" i:MenuItem.Icon="fa-solid fa-tv">
					<MenuItem Header="0.75 (ANSI X3.110 Spec)" Command="{Binding SetDisplayRatioCommand}" ToggleType="Radio" CommandParameter="0.75" IsChecked="{Binding DisplayRatio, Converter={StaticResource EqualityConverter}, ConverterParameter='0.75'}" />
					<MenuItem Header="0.78 (Byte Magazine 1983)" Command="{Binding SetDisplayRatioCommand}" ToggleType="Radio" CommandParameter="0.78" IsChecked="{Binding DisplayRatio, Converter={StaticResource EqualityConverter}, ConverterParameter='0.78'}" />
					<MenuItem Header="0.80 (PP3/Prodigy)" Command="{Binding SetDisplayRatioCommand}" ToggleType="Radio" CommandParameter="0.80" IsChecked="{Binding DisplayRatio, Converter={StaticResource EqualityConverter}, ConverterParameter='0.80'}" />
				</MenuItem>
				<MenuItem Header="_Stretch" i:MenuItem.Icon="fa-solid fa-maximize">
					<MenuItem Header="None" Command="{Binding SetStretchModeCommand}" CommandParameter="None" ToggleType="Radio" IsChecked="{Binding ImageStretch, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static Media:Stretch.None}}" />
					<MenuItem Header="Fill" Command="{Binding SetStretchModeCommand}" CommandParameter="Fill" ToggleType="Radio" IsChecked="{Binding ImageStretch, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static Media:Stretch.Fill}}" />
					<MenuItem Header="Uniform" Command="{Binding SetStretchModeCommand}" CommandParameter="Uniform" ToggleType="Radio" IsChecked="{Binding ImageStretch, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static Media:Stretch.Uniform}}" />
					<MenuItem Header="Uniform To Fill" Command="{Binding SetStretchModeCommand}" CommandParameter="UniformToFill" ToggleType="Radio" IsChecked="{Binding ImageStretch, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static Media:Stretch.UniformToFill}}" />
				</MenuItem>
			</MenuItem>
			<MenuItem Header="_Debug">
				<MenuItem Header="_Text Debug" Command="{Binding ToggleDebugTextDrawingCommand}" IsEnabled="{Binding IsFileLoaded}" ToggleType="CheckBox" IsChecked="{Binding DebugTextDrawing}" i:MenuItem.Icon="fa-solid fa-font"/>
			</MenuItem>
			<MenuItem Header="_Help">
				<MenuItem Header="_Help (github.com)" Command="{Binding HelpCommand}" i:MenuItem.Icon="fa-solid fa-question"/>
				<Separator/>
				<MenuItem Header="GitHub Code" Command="{Binding GitHubCommand}" i:MenuItem.Icon="fa-brand fa-github"/>
				<Separator/>
				<MenuItem Header="_About" Command="{Binding AboutCommand}" i:MenuItem.Icon="fa-solid fa-circle-info"/>
			</MenuItem>
		</Menu>

		<Border DockPanel.Dock="Bottom" VerticalAlignment="Bottom" Background="{DynamicResource SystemControlBackgroundBase}" Padding="5">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
				<i:Icon Value="fa-solid fa-floppy-disk" Margin="0,0,5,0" />
				<TextBlock Text="{Binding FileName}" VerticalAlignment="Center" />
				<Border Margin="10,0" Width="{DynamicResource MenuFlyoutSeparatorThemeHeight}" IsVisible="{Binding IsFileLoaded}" Background="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

				<i:Icon Value="fa-solid fa-text-width" Margin="0,0,5,0" IsVisible="{Binding IsFileLoaded}" />
				<TextBlock Text="{Binding BitWidth}" VerticalAlignment="Center" IsVisible="{Binding IsFileLoaded}" />
				<Border Margin="10,0" Width="{DynamicResource MenuFlyoutSeparatorThemeHeight}" IsVisible="{Binding IsFileLoaded}" Background="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

				<i:Icon Value="fa-solid fa-microchip" Margin="0,0,5,0" IsVisible="{Binding IsFileLoaded}" />
				<TextBlock Text="{Binding FileSystemType}" VerticalAlignment="Center" IsVisible="{Binding IsFileLoaded}" />
				<Border Margin="10,0" Width="{DynamicResource MenuFlyoutSeparatorThemeHeight}" Background="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

				<i:Icon Value="fa-solid fa-gauge" Margin="0,0,5,0" />
				<TextBlock Text="{Binding BaudRateDisplay}" VerticalAlignment="Center" />
				<Border Margin="10,0" Width="{DynamicResource MenuFlyoutSeparatorThemeHeight}" Background="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

				<i:Icon Value="fa-solid fa-display" Margin="0,0,5,0" />
				<TextBlock Text="{Binding CanvasSize}" VerticalAlignment="Center" />
				<Border Margin="10,0" Width="{DynamicResource MenuFlyoutSeparatorThemeHeight}" Background="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

				<i:Icon Value="fa-solid fa-tv" Margin="0,0,5,0" />
				<TextBlock Text="{Binding DisplayRatio}" VerticalAlignment="Center" />
				<Border Margin="10,0" Width="{DynamicResource MenuFlyoutSeparatorThemeHeight}" Background="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

				<i:Icon Value="fa-solid fa-maximize" Margin="0,0,5,0" />
				<TextBlock Text="{Binding ImageStretch}" VerticalAlignment="Center" />
				<Border Margin="10,0" Width="{DynamicResource MenuFlyoutSeparatorThemeHeight}" Background="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

				<i:Icon Value="fa-solid fa-shoe-prints" Margin="0,0,5,0" />
				<TextBlock Text="Animated" VerticalAlignment="Center" IsVisible="{Binding IsAnimated}" />
				<TextBlock Text="Static" VerticalAlignment="Center" IsVisible="{Binding !IsAnimated}" />
				<Border Margin="10,0" Width="{DynamicResource MenuFlyoutSeparatorThemeHeight}" IsVisible="{Binding IsFileLoaded}" Background="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

				<i:Icon Value="fa-solid fa-film" Margin="0,0,5,0" IsVisible="{Binding IsFileLoaded}" />
				<TextBlock Text="{Binding CurrentFrame}" VerticalAlignment="Center" IsVisible="{Binding IsFileLoaded}"/>
				<TextBlock Text="/" VerticalAlignment="Center" IsVisible="{Binding IsFileLoaded}"/>
				<TextBlock Text="{Binding TotalFrames}" VerticalAlignment="Center" IsVisible="{Binding IsFileLoaded}"/>

				<Border Margin="10,0" Width="{DynamicResource MenuFlyoutSeparatorThemeHeight}" IsVisible="{Binding HasDiagnostics}" Background="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
				<StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasDiagnostics}">
					<Button Command="{Binding ShowDiagnosticsCommand}" Background="Transparent" Padding="2,0" Cursor="Hand">
						<StackPanel Orientation="Horizontal" Spacing="4">
							<i:Icon Value="fa-solid fa-circle-xmark" Foreground="#F44" FontSize="11" IsVisible="{Binding ErrorCount}"/>
							<TextBlock Text="{Binding ErrorCount}" Foreground="#F44" FontSize="11" VerticalAlignment="Center" IsVisible="{Binding ErrorCount}"/>
							<i:Icon Value="fa-solid fa-triangle-exclamation" Foreground="#FC0" FontSize="11" IsVisible="{Binding WarningCount}"/>
							<TextBlock Text="{Binding WarningCount}" Foreground="#FC0" FontSize="11" VerticalAlignment="Center" IsVisible="{Binding WarningCount}"/>
						</StackPanel>
					</Button>
				</StackPanel>

				<Border Margin="10,0" Width="{DynamicResource MenuFlyoutSeparatorThemeHeight}" IsVisible="{Binding IsEditorMode}" Background="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
				<i:Icon Value="fa-solid fa-pen-ruler" Margin="0,0,5,0" IsVisible="{Binding IsEditorMode}" />
				<TextBlock Text="{Binding ActiveToolName}" VerticalAlignment="Center" IsVisible="{Binding IsEditorMode}"/>
				<Border Margin="10,0" Width="{DynamicResource MenuFlyoutSeparatorThemeHeight}" IsVisible="{Binding IsEditorMode}" Background="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
				<Border Width="12" Height="12" Background="{Binding ForegroundColorBrush}" BorderBrush="White" BorderThickness="1" VerticalAlignment="Center" IsVisible="{Binding IsEditorMode}" Margin="0,0,2,0"/>
				<Border Width="12" Height="12" Background="{Binding BackgroundColorBrush}" BorderBrush="Gray" BorderThickness="1" VerticalAlignment="Center" IsVisible="{Binding IsEditorMode}"/>
			</StackPanel>
		</Border>

		<!-- Editor Toolbar (left dock) -->
		<Border DockPanel.Dock="Left" Background="{DynamicResource SystemControlBackgroundBase}" Padding="2" IsVisible="{Binding IsEditorMode}">
			<StackPanel Orientation="Vertical" Spacing="2">
				<RadioButton GroupName="EditorTools" IsChecked="{Binding IsSelectToolActive}" ToolTip.Tip="Select"
							 Command="{Binding SetActiveToolCommand}" CommandParameter="Select">
					<i:Icon Value="fa-solid fa-arrow-pointer" FontSize="16"/>
				</RadioButton>
				<RadioButton GroupName="EditorTools" IsChecked="{Binding IsMovePenToolActive}" ToolTip.Tip="Move Pen"
							 Command="{Binding SetActiveToolCommand}" CommandParameter="MovePen">
					<i:Icon Value="fa-solid fa-crosshairs" FontSize="16"/>
				</RadioButton>
				<RadioButton GroupName="EditorTools" IsChecked="{Binding IsLineToolActive}" ToolTip.Tip="Line"
							 Command="{Binding SetActiveToolCommand}" CommandParameter="Line">
					<i:Icon Value="fa-solid fa-minus" FontSize="16"/>
				</RadioButton>
				<RadioButton GroupName="EditorTools" IsChecked="{Binding IsRectangleToolActive}" ToolTip.Tip="Rectangle"
							 Command="{Binding SetActiveToolCommand}" CommandParameter="Rectangle">
					<i:Icon Value="fa-solid fa-square" FontSize="16"/>
				</RadioButton>
				<RadioButton GroupName="EditorTools" IsChecked="{Binding IsPolygonToolActive}" ToolTip.Tip="Polygon"
							 Command="{Binding SetActiveToolCommand}" CommandParameter="Polygon">
					<i:Icon Value="fa-solid fa-draw-polygon" FontSize="16"/>
				</RadioButton>
				<RadioButton GroupName="EditorTools" IsChecked="{Binding IsArcToolActive}" ToolTip.Tip="Arc"
							 Command="{Binding SetActiveToolCommand}" CommandParameter="Arc">
					<i:Icon Value="fa-solid fa-circle-notch" FontSize="16"/>
				</RadioButton>
				<RadioButton GroupName="EditorTools" IsChecked="{Binding IsTextToolActive}" ToolTip.Tip="Text"
							 Command="{Binding SetActiveToolCommand}" CommandParameter="Text">
					<i:Icon Value="fa-solid fa-font" FontSize="16"/>
				</RadioButton>
				<Separator Margin="0,4"/>
				<CheckBox IsChecked="{Binding IsFilledMode}" ToolTip.Tip="Filled">
					<i:Icon Value="fa-solid fa-fill" FontSize="16"/>
				</CheckBox>
				<Separator Margin="0,4"/>
				<CheckBox IsChecked="{Binding GridSettings.IsVisible}" ToolTip.Tip="Grid" Command="{Binding ToggleGridCommand}">
					<i:Icon Value="fa-solid fa-border-all" FontSize="16"/>
				</CheckBox>
				<CheckBox IsChecked="{Binding GridSettings.IsSnapEnabled}" ToolTip.Tip="Snap to Grid" Command="{Binding ToggleSnapCommand}">
					<i:Icon Value="fa-solid fa-magnet" FontSize="16"/>
				</CheckBox>
			</StackPanel>
		</Border>

		<!-- Color Picker Panel (left dock, below toolbar) -->
		<Border DockPanel.Dock="Left" Background="{DynamicResource SystemControlBackgroundBase}" Padding="4" IsVisible="{Binding IsEditorMode}" Width="44">
			<StackPanel Orientation="Vertical" Spacing="2">
				<TextBlock Text="FG" FontSize="10" HorizontalAlignment="Center"/>
				<Border Width="28" Height="28" BorderBrush="White" BorderThickness="2" CornerRadius="2" HorizontalAlignment="Center"
						Background="{Binding ForegroundColorBrush}"/>
				<TextBlock Text="BG" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"/>
				<Border Width="28" Height="28" BorderBrush="Gray" BorderThickness="2" CornerRadius="2" HorizontalAlignment="Center"
						Background="{Binding BackgroundColorBrush}"/>
				<Separator Margin="0,4"/>
				<ItemsControl ItemsSource="{Binding PaletteColors}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel ItemWidth="18" ItemHeight="18"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Button Width="16" Height="16" Padding="0" Margin="1"
									Background="{Binding Brush}"
									Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectPaletteColorCommand}"
									CommandParameter="{Binding Index}"/>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>
		</Border>

		<Grid Background="#222222">
			<Image Source="{Binding CanvasImage}" Name="CanvasImageControl"
				   HorizontalAlignment="Center" VerticalAlignment="Center"
				   Stretch="{Binding ImageStretch}"/>
			<Canvas Name="EditorOverlay" Background="Transparent"
					IsVisible="{Binding IsEditorMode}"/>
		</Grid>
	</DockPanel>
</Window>
