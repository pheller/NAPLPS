<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:NAPLPSApp.ViewModels"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:views="clr-namespace:NAPLPSApp.Views"
		xmlns:i="https://github.com/projektanker/icons.avalonia"
		xmlns:converters="clr-namespace:NAPLPSApp.Converters"
		xmlns:Media="using:Avalonia.Media"
		mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
		x:Class="NAPLPSApp.Views.AddCommandWindow"
		x:DataType="vm:AddCommandViewModel"
		Icon="/Assets/naplps.ico"
		Title="Add Command">
</Window>
