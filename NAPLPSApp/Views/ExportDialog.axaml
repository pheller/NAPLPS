<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:NAPLPSApp.ViewModels"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="440" d:DesignHeight="500"
		Width="440" Height="500"
		x:Class="NAPLPSApp.Views.ExportDialog"
		x:DataType="vm:ExportDialogViewModel"
		Icon="/Assets/naplps.ico"
		Title="Export Image"
		WindowStartupLocation="CenterOwner"
		CanResize="False">
	<DockPanel Margin="14">
		<StackPanel DockPanel.Dock="Top" Orientation="Vertical" Spacing="10">

			<TextBlock Text="Export Image" FontWeight="Bold" FontSize="16"/>

			<Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
				<TextBlock Grid.Row="0" Grid.Column="0" Text="Format:" VerticalAlignment="Center"/>
				<ComboBox Grid.Row="0" Grid.Column="1" SelectedIndex="{Binding FormatIndex}" HorizontalAlignment="Stretch"
						  ItemsSource="{Binding FormatOptions}"/>

				<TextBlock Grid.Row="1" Grid.Column="0" Text="Scale:" VerticalAlignment="Center"/>
				<StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="4">
					<Button Content="0.5x" Command="{Binding SetScaleCommand}" CommandParameter="0.5"/>
					<Button Content="1x" Command="{Binding SetScaleCommand}" CommandParameter="1"/>
					<Button Content="2x" Command="{Binding SetScaleCommand}" CommandParameter="2"/>
					<Button Content="4x" Command="{Binding SetScaleCommand}" CommandParameter="4"/>
					<Button Content="8x" Command="{Binding SetScaleCommand}" CommandParameter="8"/>
					<NumericUpDown Value="{Binding Scale}" Minimum="0.1" Maximum="16" Increment="0.25" FormatString="0.##" Width="90"/>
				</StackPanel>
			</Grid>

			<Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,1,0,0" Margin="0,4"/>

			<Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="4">
				<TextBlock Grid.Row="0" Grid.Column="0" Text="Source:" VerticalAlignment="Center"/>
				<TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Opacity="0.8">
					<Run Text="{Binding SourceWidth}"/><Run Text=" x "/><Run Text="{Binding SourceHeight}"/><Run Text=" px (native)"/>
				</TextBlock>

				<TextBlock Grid.Row="1" Grid.Column="0" Text="Output:" VerticalAlignment="Center"/>
				<TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold">
					<Run Text="{Binding OutputWidth}"/><Run Text=" x "/><Run Text="{Binding OutputHeight}"/><Run Text=" px"/>
				</TextBlock>
			</Grid>

			<CheckBox Content="Transparent background" IsChecked="{Binding TransparentBackground}" IsEnabled="{Binding CanSetTransparentBackground}"
					  ToolTip.Tip="PNG/GIF only. Leaves the canvas background fully transparent instead of filling with black."/>

			<Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsEnabled="{Binding CanSetJpegQuality}">
				<TextBlock Grid.Column="0" Text="JPEG Quality:" VerticalAlignment="Center"/>
				<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
					<Slider Minimum="1" Maximum="100" Value="{Binding JpegQuality}" Width="200" VerticalAlignment="Center"/>
					<TextBlock Text="{Binding JpegQuality}" VerticalAlignment="Center" Width="30"/>
				</StackPanel>
			</Grid>

			<!-- APNG-only controls. The frame range lets the user clip the output to a
			     contiguous slice of the rendered animation. Estimated frames is filled in
			     by MainWindow before showing the dialog (it does a dry-run render). -->
			<Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,1,0,0" Margin="0,4" IsVisible="{Binding IsApng}"/>
			<StackPanel Spacing="6" IsVisible="{Binding IsApng}">
				<TextBlock Text="APNG Options" FontWeight="Bold"/>
				<Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
					<TextBlock Grid.Row="0" Grid.Column="0" Text="Frame delay (ms):" VerticalAlignment="Center"/>
					<NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding ApngFrameDelayMs}" Minimum="10" Maximum="5000" Increment="10" FormatString="0"/>

					<TextBlock Grid.Row="1" Grid.Column="0" Text="Blink cycles:" VerticalAlignment="Center" ToolTip.Tip="Number of additional blink-animation cycles to append after the draw sequence (0 = none)"/>
					<NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding ApngBlinkCycles}" Minimum="0" Maximum="100" Increment="1" FormatString="0"/>

					<TextBlock Grid.Row="2" Grid.Column="0" Text="Loop:" VerticalAlignment="Center"/>
					<CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding ApngLoop}" Content="Loop indefinitely"/>
				</Grid>
				<TextBlock Text="Frame range (1-based, 0=all):" FontSize="11" Opacity="0.8" Margin="0,4,0,0"/>
				<Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="6">
					<TextBlock Grid.Column="0" Text="Start:" VerticalAlignment="Center"/>
					<NumericUpDown Grid.Column="1" Value="{Binding ApngStartFrame}" Minimum="0" Maximum="100000" Increment="1" FormatString="0"/>
					<TextBlock Grid.Column="2" Text="End:" VerticalAlignment="Center"/>
					<NumericUpDown Grid.Column="3" Value="{Binding ApngEndFrame}" Minimum="0" Maximum="100000" Increment="1" FormatString="0"/>
				</Grid>
				<TextBlock FontSize="10" Opacity="0.7"
						   Text="{Binding ApngEstimatedFrames, StringFormat='Estimated total frames: {0}'}"/>
			</StackPanel>

		</StackPanel>

		<StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,10,0,0">
			<Button Content="Cancel" Command="{Binding CancelCommand}" Width="90"/>
			<Button Content="Export..." Command="{Binding OkCommand}" Width="90" IsDefault="True"
					Background="{DynamicResource SystemAccentColor}"/>
		</StackPanel>

		<Border/>
	</DockPanel>
</Window>
